--- a/tina4_python/database/postgres.py
+++ b/tina4_python/database/postgres.py
@@ -144,18 +144,69 @@
         cursor = self._conn.cursor(cursor_factory=psycopg2.extras.RealDictCursor)
 
         # Count total rows
+        #
+        # Issue #46: the count probe used to be a bare ``try/except
+        # Exception: total = 0`` with no SAVEPOINT or rollback. On
+        # PostgreSQL the connection is opened with ``autocommit = False``
+        # (see ``connect()``), so any error inside the count probe
+        # poisons the outer transaction — the next statement on the
+        # same connection then raises ``InFailedSqlTransaction``
+        # (*"current transaction is aborted, commands ignored until
+        # end of transaction block"*), and that is the only message
+        # the caller ever sees. The original cause (e.g. ``operator
+        # does not exist: boolean = integer`` when a filter like
+        # ``is_deleted = 0`` hits a BOOLEAN column) was discarded.
+        #
+        # Fix: wrap the probe in a SAVEPOINT — same shape as the
+        # ``lastval()`` probe a few lines up (fix for issue #38). On
+        # failure we ROLLBACK TO SAVEPOINT so the outer transaction
+        # stays usable, fall back to ``total = 0`` as before, and
+        # ``Log.error`` the original cause so the user has a trace.
         count_sql = f"SELECT COUNT(*) AS cnt FROM ({sql}) AS _count_subquery"
+        cursor.execute("SAVEPOINT _t4_count_probe")
         try:
             self._safe_execute(cursor, count_sql, params)
             total = cursor.fetchone()["cnt"]
-        except Exception:
+            cursor.execute("RELEASE SAVEPOINT _t4_count_probe")
+        except Exception as e:
+            try:
+                cursor.execute("ROLLBACK TO SAVEPOINT _t4_count_probe")
+            except Exception:
+                pass  # cleanup failure is not fatal
             total = 0
+            try:
+                from tina4_python.debug import Log
+                Log.error(
+                    "PostgreSQL count probe failed; pagination total set to 0",
+                    error=str(e),
+                    sql=sql,
+                )
+            except Exception:
+                pass  # logging must never break the data path
 
         # Apply pagination
+        #
+        # Issue #46 (adversarial finding): even with the count-probe
+        # SAVEPOINT in place, a failure HERE still poisoned the
+        # connection for every subsequent statement because the
+        # paginated query was running raw. Wrap it in its own
+        # SAVEPOINT so a failure rolls back to a clean state, the
+        # original error is re-raised (callers expect the bad SQL
+        # error to surface), and the underlying connection stays
+        # usable for the next call.
         paginated_sql = f"{sql} LIMIT %s OFFSET %s"
         paginated_params = (params or []) + [limit, offset]
-        self._safe_execute(cursor, paginated_sql, paginated_params)
-        rows = [self._decode_blobs(dict(row)) for row in cursor.fetchall()]
+        cursor.execute("SAVEPOINT _t4_paginated")
+        try:
+            self._safe_execute(cursor, paginated_sql, paginated_params)
+            rows = [self._decode_blobs(dict(row)) for row in cursor.fetchall()]
+            cursor.execute("RELEASE SAVEPOINT _t4_paginated")
+        except Exception:
+            try:
+                cursor.execute("ROLLBACK TO SAVEPOINT _t4_paginated")
+            except Exception:
+                pass  # cleanup failure is not fatal
+            raise
 
         return DatabaseResult(records=rows, count=total, limit=limit, offset=offset, sql=sql, adapter=self)
 
