# Copy to .env (which is gitignored). The Python suite needs a database
# connected — see CLAUDE.md "Running / testing". Start Postgres with
# `docker compose up -d` from the repo root, then these defaults work as-is.
TINA4_DEBUG=true
TINA4_LOG_LEVEL=ALL
TINA4_DATABASE_URL=postgresql://postgres:tina4test@localhost:5432/tina4testingdb
